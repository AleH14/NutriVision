<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".PerfilActivity">

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_menu"
        app:itemIconTint="@color/nav_icon_color"
        app:itemTextColor="@color/nav_icon_color"
        app:itemRippleColor="@android:color/transparent"
        app:itemBackground="@android:color/transparent"
        app:itemActiveIndicatorStyle="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="92dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/parentLinearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="96dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/btnBackPerfil"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/montserrat"
                        android:gravity="center"
                        android:text="‹"
                        android:textColor="@color/gris_claro"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTituloPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mi Perfil"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:fontFamily="@font/montserrat"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvNombreUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Usuario NutriVision"
                android:textColor="@color/black"
                android:textSize="28sp"
                android:fontFamily="@font/montserrat"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="INFORMACIÓN"
                    android:textColor="@color/gris_claro"
                    android:textSize="16sp"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnEditarPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✎ Editar"
                    android:textColor="#22C55E"
                    android:textSize="15sp"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#D7D7D7">

                <LinearLayout
                    android:id="@+id/linearLayoutInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Fila 1: EDAD, ALTURA, GÉNERO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- EDAD -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EDAD"
                                android:textColor="@color/gray"
                                android:textSize="14sp"
                                android:fontFamily="@font/montserrat" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal"
                                android:gravity="bottom">

                                <EditText
                                    android:id="@+id/editEdad"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="21"
                                    android:textColor="@color/black"
                                    android:textSize="22sp"
                                    android:fontFamily="@font/montserrat"
                                    android:textStyle="bold"
                                    android:inputType="number"
                                    android:background="@android:color/transparent"
                                    android:enabled="false"
                                    android:focusable="false"
                                    android:minWidth="50dp"
                                    android:hint="0"
                                    android:textColorHint="@color/gray"
                                    android:gravity="center"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginBottom="2dp"
                                    android:text="años"
                                    android:textColor="@color/gray"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/montserrat" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ALTURA -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ALTURA"
                                android:textColor="@color/gray"
                                android:textSize="14sp"
                                android:fontFamily="@font/montserrat" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal"
                                android:gravity="bottom">

                                <EditText
                                    android:id="@+id/editAltura"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="150"
                                    android:textColor="@color/black"
                                    android:textSize="22sp"
                                    android:fontFamily="@font/montserrat"
                                    android:textStyle="bold"
                                    android:inputType="numberDecimal"
                                    android:background="@android:color/transparent"
                                    android:enabled="false"
                                    android:focusable="false"
                                    android:minWidth="60dp"
                                    android:hint="0"
                                    android:textColorHint="@color/gray"
                                    android:gravity="center"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginBottom="2dp"
                                    android:text="cm"
                                    android:textColor="@color/gray"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/montserrat" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- GÉNERO (vertical en modo edición) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GÉNERO"
                                android:textColor="@color/gray"
                                android:textSize="14sp"
                                android:fontFamily="@font/montserrat" />

                            <!-- TextView para modo lectura -->
                            <TextView
                                android:id="@+id/tvGenero"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Femenino"
                                android:textColor="@color/black"
                                android:textSize="18sp"
                                android:fontFamily="@font/montserrat"
                                android:textStyle="bold"
                                android:visibility="visible" />

                            <!-- LinearLayout para modo edición (vertical) -->
                            <LinearLayout
                                android:id="@+id/llGeneroEdicion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/chipGeneroFemenino"
                                    android:layout_width="match_parent"
                                    android:layout_height="36dp"
                                    android:layout_marginBottom="6dp"
                                    android:background="@drawable/bg_profile_chip_selected"
                                    android:gravity="center"
                                    android:text="Femenino"
                                    android:textColor="@color/black"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/montserrat"
                                    android:textStyle="bold"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/chipGeneroMasculino"
                                    android:layout_width="match_parent"
                                    android:layout_height="36dp"
                                    android:layout_marginTop="6dp"
                                    android:background="@drawable/bg_profile_chip"
                                    android:gravity="center"
                                    android:text="Masculino"
                                    android:textColor="@color/black"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/montserrat"
                                    android:textStyle="bold"
                                    android:clickable="true"
                                    android:focusable="true" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Título OBJETIVO PERSONAL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="OBJETIVO PERSONAL"
                        android:textColor="@color/gray"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat" />

                    <!-- Chips de Objetivo Personal con padding interno -->
                    <LinearLayout
                        android:id="@+id/objetivoChipsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/chipMantenerPeso"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/bg_profile_chip_selected"
                                android:gravity="center"
                                android:text="Mantener Peso"
                                android:textColor="@color/black"
                                android:textSize="15sp"
                                android:fontFamily="@font/montserrat"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/chipAumentarMusculo"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_profile_chip"
                                android:gravity="center"
                                android:text="Aumentar músculo"
                                android:textColor="@color/black"
                                android:textSize="15sp"
                                android:fontFamily="@font/montserrat"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/chipSubirPeso"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/bg_profile_chip"
                                android:gravity="center"
                                android:text="Subir Peso"
                                android:textColor="@color/black"
                                android:textSize="15sp"
                                android:fontFamily="@font/montserrat"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/chipBajarPeso"
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_profile_chip"
                                android:gravity="center"
                                android:text="Bajar Peso"
                                android:textColor="@color/black"
                                android:textSize="15sp"
                                android:fontFamily="@font/montserrat"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- PESO OBJETIVO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PESO OBJETIVO"
                            android:textColor="@color/gray"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <EditText
                                android:id="@+id/editPesoObjetivo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="110"
                                android:textColor="@color/black"
                                android:textSize="22sp"
                                android:fontFamily="@font/montserrat"
                                android:textStyle="bold"
                                android:inputType="numberDecimal"
                                android:background="@android:color/transparent"
                                android:enabled="false"
                                android:focusable="false"
                                android:minWidth="60dp"
                                android:hint="0"
                                android:textColorHint="@color/gray"
                                android:gravity="center"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="2dp"
                                android:text="lb"
                                android:textColor="@color/gray"
                                android:textSize="13sp"
                                android:fontFamily="@font/montserrat" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Botón Guardar Cambios (centrado) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuardarCambios"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="20dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:text="Guardar"
                        android:textAllCaps="false"
                        android:fontFamily="@font/montserrat"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/success_green"
                        app:cornerRadius="20dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/success_green"
                        app:backgroundTint="@android:color/transparent"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/goal_card_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/orange">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:gravity="center"
                            android:text="🔥"
                            android:textSize="30sp"
                            android:textColor="@color/orange"
                            android:fontFamily="@font/montserrat" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meta Diaria"
                                android:textColor="@color/gris_claro"
                                android:textSize="16sp"
                                android:fontFamily="@font/montserrat" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="bottom">

                                <TextView
                                    android:id="@+id/tvMetaDiariaKcal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1,850"
                                    android:textColor="@color/black"
                                    android:textSize="32sp"
                                    android:fontFamily="@font/montserrat"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:layout_marginBottom="6dp"
                                    android:text="kcal"
                                    android:textColor="@color/gray"
                                    android:textSize="18sp"
                                    android:fontFamily="@font/montserrat" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalcularMetaDiaria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="Calcular Meta"
                        android:textAllCaps="false"
                        android:fontFamily="@font/montserrat"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/orange"
                        app:cornerRadius="20dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/orange"
                        app:backgroundTint="@android:color/transparent" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Esta cálculo fue hecho mediante IA por medio de los datos brindados en la información de arriba"
                        android:textColor="@color/gray"
                        android:textSize="12sp"
                        android:fontFamily="@font/montserrat" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botón Cerrar Sesión -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="26dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="18dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FF4D4F">

                <TextView
                    android:id="@+id/btnCerrarSesion"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="↪  Cerrar Sesión"
                    android:textColor="#EF4444"
                    android:textSize="17sp"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>