<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InicioActivity">

    <!-- CONTENIDO CON SCROLL -->


    <!-- Barra de navegacion-->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <!--Card view de meta diaria-->

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="140dp"
                android:fontFamily="@font/montserrat"
                android:text="Hoy es un gran día para comer sano"
                android:textColor="#334155"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.202"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="104dp"
                android:fontFamily="@font/montserrat"
                android:text="¡Hola Usuario!"
                android:textColor="#334155"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.127"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_calorias"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:background="@drawable/card_border_orange"
                app:layout_constraintTop_toBottomOf="@id/textView3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_border_orange"
                    android:padding="16dp">

                    <!-- Título -->
                    <TextView
                        android:id="@+id/tv_meta_diaria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Meta Diaria"
                        android:textSize="16sp"
                        android:textColor="#334155"
                        android:fontFamily="@font/montserrat"/>

                    <!-- Fila de calorías + porcentaje -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp">

                        <!-- Calorías consumidas -->
                        <TextView
                            android:id="@+id/tv_calorias_consumidas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1,850 /"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#334155"
                            android:fontFamily="@font/montserrat"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <!-- Calorías meta -->
                        <TextView
                            android:id="@+id/tv_calorias_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 2,500 kcal"
                            android:textSize="15sp"
                            android:textColor="#64748B"
                            android:fontFamily="@font/montserrat"
                            android:fontWeight="600"
                            android:layout_marginStart="4dp"
                            app:layout_constraintStart_toEndOf="@id/tv_calorias_consumidas"
                            app:layout_constraintTop_toTopOf="@id/tv_calorias_consumidas"
                            app:layout_constraintBottom_toBottomOf="@id/tv_calorias_consumidas"/>

                        <!-- Porcentaje -->
                        <TextView
                            android:id="@+id/tv_porcentaje"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="74%"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="#F86E00"
                            android:fontFamily="@font/montserrat"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tv_calorias_consumidas"
                            app:layout_constraintBottom_toBottomOf="@id/tv_calorias_consumidas"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <!-- Barra de progreso personalizada -->
                    <ProgressBar
                        android:id="@+id/progress_calorias"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:progress="74"
                        android:max="100"
                        android:progressDrawable="@drawable/progress_orange"
                        android:layout_marginTop="8dp"
                        android:indeterminate="false"
                        android:clipToOutline="true"/>


                    <!-- Porcentaje restante con icono -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical">

                        <!-- Icono pequeño -->
                        <ImageView
                            android:id="@+id/icon_kcal"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/alert"
                          android:contentDescription="Kcal"
                         app:tint="#475569"
                          android:layout_marginEnd="4dp"/>

                        <!-- Texto restante -->
                        <TextView
                            android:id="@+id/tv_restante"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Te quedan 650 kcal para completar el día"
                            android:textSize="14sp"
                            android:textColor="#475569"
                            android:fontFamily="@font/montserrat"
                            android:fontWeight="600"/>
                    </LinearLayout>




                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_camara"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:background="@drawable/card_border_orange"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_calorias">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="@drawable/card_border_green"
                    android:gravity="center"
                    android:padding="16dp">

                    <!-- Icono grande en el medio -->
                    <ImageView
                        android:id="@+id/btn_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/camera_filled"
                        android:contentDescription="Icono botón"/>


                    <TextView
                        android:id="@+id/btn_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escanear Comida"
                        android:textSize="16sp"
                        android:textColor="#334155"
                        android:fontFamily="@font/montserrat"
                        android:fontWeight="700"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:gravity="center"/>
                    <TextView
                        android:id="@+id/btn_text2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toma una fotografia de tu plato de comida"
                        android:textSize="12sp"
                        android:textColor="#334155"
                        android:fontFamily="@font/montserrat"
                        android:fontWeight="600"
                        android:layout_marginTop="8dp"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="108dp"
                android:layout_height="66dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.201"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.055"
                app:srcCompat="@drawable/logo" />

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="210dp"
                android:layout_height="53dp"

                android:layout_marginTop="36dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.616"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/logo_letra" />


        </androidx.constraintlayout.widget.ConstraintLayout>


            <LinearLayout
                android:id="@+id/resumen_nutricional_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingStart="16dp"
                android:layout_marginTop="7dp"
                app:layout_constraintTop_toBottomOf="@id/btn_camara"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Resumen nutricional de Hoy"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#334155"
                    android:layout_marginBottom="4dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <!-- Nombre del macro -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="600"
                        android:text="Proteínas"
                        android:fontFamily="@font/montserrat"
                        android:textSize="14sp"
                        android:textColor="#334155"/>

                    <!-- Cantidad a la derecha -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="85 / 120 g"
                        android:textSize="14sp"
                        android:textColor="#334155"/>
                </LinearLayout>

                <!-- Barra de progreso debajo -->
                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="120"
                    android:progress="85"
                    android:layout_marginBottom="8dp"
                    android:progressDrawable="@drawable/progress_yellow"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <!-- Nombre del macro -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="600"
                        android:text="Carbohidratos"
                        android:fontFamily="@font/montserrat"
                        android:textSize="14sp"
                        android:textColor="#334155"/>

                    <!-- Cantidad a la derecha -->
                    <TextView
                        android:fontFamily="@font/montserrat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85 / 120 g"
                        android:textSize="14sp"
                        android:textColor="#334155"/>
                </LinearLayout>

                <!-- Barra de progreso debajo -->
                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="120"
                    android:progress="85"
                    android:layout_marginBottom="8dp"
                    android:progressDrawable="@drawable/progress_cyan"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <!-- grasas -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="600"
                        android:fontFamily="@font/montserrat"
                        android:text="Grasas"
                        android:textSize="14sp"
                        android:textColor="#334155"/>

                    <!-- Cantidad a la derecha -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="85 / 120 g"
                        android:textSize="14sp"
                        android:textColor="#334155"/>
                </LinearLayout>

                <!-- Barra de progreso debajo -->
                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="120"
                    android:progress="85"
                    android:layout_marginBottom="8dp"
                    android:progressDrawable="@drawable/progress_purple"/>
            </LinearLayout>

        </LinearLayout>


    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/white"

        app:menu="@menu/bottom_menu"
        app:itemIconTint="@color/nav_icon_color"
        app:itemTextColor="@color/nav_icon_color"
        app:itemRippleColor="@android:color/transparent"
        app:itemBackground="@android:color/transparent"
        app:itemActiveIndicatorStyle="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>





</androidx.constraintlayout.widget.ConstraintLayout>